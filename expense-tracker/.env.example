# Google OAuth Client ID - required for Google Sign-In
# Get this from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# Backend API URL - defaults to localhost:8080 in local dev
# On Railway: set this to your backend Railway URL
# Example: https://expense-tracker-backend-xxxx.up.railway.app/api
VITE_API_URL="http://localhost:8080/api"
